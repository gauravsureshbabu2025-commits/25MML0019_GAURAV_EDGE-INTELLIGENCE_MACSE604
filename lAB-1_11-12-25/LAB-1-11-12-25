    "import matplotlib.pyplot as plt\n",
    "import numpy as np\n",
    "\n",
    "# Show first 30 images\n",
    "n = 30\n",
    "rows = 6\n",
    "cols = 5  # 6 × 5 = 30 slots\n",
    "\n",
    "plt.figure(figsize=(15, 10))\n",
    "\n",
    "for i in range(n):\n",
    "    sample = ds[i]\n",
    "    img = sample['images']\n",
    "\n",
    "    # Convert torch tensors if needed\n",
    "    if hasattr(img, \"numpy\"):\n",
    "        img = img.numpy()\n",
    "\n",
    "    # If channel-first, convert to HWC\n",
    "    if img.ndim == 3 and img.shape[0] in (1, 3):\n",
    "        img = np.transpose(img, (1, 2, 0))\n",
    "\n",
    "    plt.subplot(rows, cols, i + 1)\n",
    "    plt.imshow(img)\n",
    "    plt.axis(\"off\")\n",
    "    plt.title(f\"Image {i}\")\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
